{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other", "prefer_not_to_say"] },
        "isUploader": { "type": "boolean" },
        "totalVotesReceived": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email"]
    },
    "Upload": {
      "title": "Image Upload",
      "description": "Metadata for an uploaded image.",
      "type": "object",
      "properties": {
        "uploaderId": { "type": "string" },
        "uploaderName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "upvotes": { "type": "integer" },
        "downvotes": { "type": "integer" },
        "totalVotes": { "type": "integer" },
        "dayKey": { "type": "string", "description": "Format YYYY-MM-DD to restrict one upload per day." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uploaderId", "imageUrl", "dayKey"]
    },
    "Vote": {
      "title": "Vote",
      "description": "Record of a user's vote on an image.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "uploadId": { "type": "string" },
        "type": { "type": "string", "enum": ["up", "down"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "uploadId", "type"]
    },
    "WhitelistedEmail": {
      "title": "Whitelisted Email",
      "description": "Emails permitted to upload images.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by UID."
    },
    "/uploads/{uploadId}": {
      "schema": "Upload",
      "description": "Gallery uploads."
    },
    "/votes/{voteId}": {
      "schema": "Vote",
      "description": "Vote records. ID is usually userId_uploadId."
    },
    "/whitelist/{email}": {
      "schema": "WhitelistedEmail",
      "description": "Whitelisted emails for uploading."
    }
  }
}
