rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.uid == 'uIpa8wjNVVbs7T8fcVnb8LPKMCw2' ||
        request.auth.uid == 'xWFpoRzp0bUq1x67w0kcO890EoU2' ||
        ('email' in request.auth.token && (
          request.auth.token.email == 'okhaiuri@gmail.com' || 
          request.auth.token.email == 'ogboumahokhai@gmail.com' || 
          (request.auth.token.email_verified == true && request.auth.token.email.matches('.*admin.*'))
        ))
      ); 
    }
    
    function isWhitelisted() {
      return isSignedIn() && (
        isAdmin() || 
        ('email' in request.auth.token && exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email)))
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalVotesReceived', 'isUploader']) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['isUploader']) && isWhitelisted())
        )) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalVotesReceived']) &&
         (request.resource.data.totalVotesReceived == resource.data.totalVotesReceived + 1 || 
          request.resource.data.totalVotesReceived == resource.data.totalVotesReceived - 1))
      );
    }

    match /uploads/{uploadId} {
      allow read: if true;
      allow create: if isWhitelisted() && request.resource.data.uploaderId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && (
        (resource.data.uploaderId == request.auth.uid && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['upvotes', 'downvotes', 'totalVotes'])) || 
        (
          resource.data.uploaderId != request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes', 'totalVotes']) &&
          !exists(/databases/$(database)/documents/votes/$(request.auth.uid + "_" + uploadId)) &&
          (
            (request.resource.data.upvotes == resource.data.upvotes + 1 && request.resource.data.downvotes == resource.data.downvotes) ||
            (request.resource.data.downvotes == resource.data.downvotes + 1 && request.resource.data.upvotes == resource.data.upvotes)
          ) &&
          request.resource.data.totalVotes == request.resource.data.upvotes - request.resource.data.downvotes
        )
      ));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uploaderId == request.auth.uid);
    }

    match /daily_upload_log/{logId} {
      allow read: if true;
      allow create, update: if isWhitelisted() && logId.split('_')[0] == request.auth.uid;
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId && voteId == request.auth.uid + '_' + request.resource.data.uploadId;
      allow update, delete: if false;
    }

    match /whitelist/{email} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && 'email' in request.auth.token && request.auth.token.email == email);
    }
  }
}
